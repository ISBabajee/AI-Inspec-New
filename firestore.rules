rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Collection match rules

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 2. Clients Collection
    match /clients/{clientId} {
      allow read, write: if true;
    }

    // 3. SiteLocations Collection
    match /siteLocations/{locationId} {
      allow read, write: if true;
    }

    // 4. Equipment Collection
    match /equipment/{equipmentId} {
      allow read, write: if true;
    }

    // 5. Inspections Collection
    match /inspections/{inspectionId} {
      allow read, write: if true;
    }

    // 6. Login Records Collection
    match /loginRecords/{recordId} {
      allow read, write: if true;
    }

    // 7. Test Collection
    match /test/{testId} {
      allow read, write: if true;
    }
  }
}
